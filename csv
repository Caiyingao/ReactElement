// ==================== 请求函数 ====================
async function fetchAndExportHMDBCSV(queryMasses, filename = "hmdb_results.csv") {
    if (!queryMasses || !queryMasses.length) {
        console.error("请提供 queryMasses 数组");
        return;
    }

    const resultObj = {};
    queryMasses.forEach(mz => resultObj[mz] = []);

    const body = `utf8=%E2%9C%93&authenticity_token=EKnpAIE2llarN31hebVV9MjZcWlYmA4dkhlmGUBZjfM19%2BqMadiiJCd4Rkr9UEbT1WHl6z8lLSwXds1FoKE%2Fwg%3D%3D&query_masses=${queryMasses.join("+%0D%0A")}&ms_search_ion_mode=negative&adduct_type%5B%5D=M-H&adduct_type%5B%5D=M-H20-H&adduct_type%5B%5D=M%2BCl&adduct_type%5B%5D=M%2BFA-H&tolerance=10&tolerance_units=ppm&ccs_predictors=&ccs_tolerance=&commit=Search`;

    try {
        const response = await fetch("https://hmdb.ca/spectra/ms/search", {
            method: "POST",
            headers: {
                "accept": "text/html,application/xhtml+xml,application/xml;q=0.9,image/avif,image/webp,image/apng,*/*;q=0.8,application/signed-exchange;v=b3;q=0.7",
                "accept-language": "zh-CN,zh;q=0.9,en;q=0.8,en-GB;q=0.7,en-US;q=0.6",
                "cache-control": "no-cache",
                "content-type": "application/x-www-form-urlencoded",
                "pragma": "no-cache",
                "priority": "u=0, i",
                "sec-ch-ua": "\"Chromium\";v=\"146\", \"Not-A.Brand\";v=\"24\", \"Microsoft Edge\";v=\"146\"",
                "sec-ch-ua-arch": "\"x86\"",
                "sec-ch-ua-bitness": "\"64\"",
                "sec-ch-ua-full-version": "\"146.0.3856.62\"",
                "sec-ch-ua-full-version-list": "\"Chromium\";v=\"146.0.7680.80\", \"Not-A.Brand\";v=\"24.0.0.0\", \"Microsoft Edge\";v=\"146.0.3856.62\"",
                "sec-ch-ua-mobile": "?0",
                "sec-ch-ua-model": "\"\"",
                "sec-ch-ua-platform": "\"Windows\"",
                "sec-ch-ua-platform-version": "\"19.0.0\"",
                "sec-fetch-dest": "document",
                "sec-fetch-mode": "navigate",
                "sec-fetch-site": "same-origin",
                "sec-fetch-user": "?1",
                "upgrade-insecure-requests": "1",
                "cookie": "_ga=GA1.2.613989523.1761656778; _gid=GA1.2.756048336.1774101066; _gat=1; cf_clearance=7HLX9xa1mF88c34b9IQeuPng3AFNdBJvI5SYWU1AJcA-1774185006-1.2.1.1-tgTDm5TFz4TYRArGLMwF3KpCflfDuBFuwMYANYqY3VWibxOtibPEzJ2OJvnDhbSeQqVyEPYFTF5_C2w5FeUCcux.THXxx7vIcRcmqgW5fUwTu8GednJh8rG4NCsgZU0M.e2RJM7aq0HoLUA4M1cDA_LHww1mLSY8jWDOrMgsF62q7dNt0f1dVVtlMqVoWkgHVTwjYTuwbTMGjBye4IjuqCf4ZxcvGtlUdr8Ugo9VqUY8fvpOR6CZd0oWRGAHZ_s5; _hmdb_session=eHpnTk04WkVUQSt2UEQyK1JCWFpuUDZGcHRmV2Zhc2ZwNk9ZV1MyTHpNVlR5SGJudG1iWnoxUUJqMCtlV21yTnlHOU0xZHp2MW1QQzJUdTE5ZEJGbmMvWS9MTHZuazJyRXd4ZzVFbFo4NkcxY3ZwcFBPd3hvNEZ4Qmo0YXM4VHA3Y3E4dDhGWEUvTUJoWG85b09QYjRBPT0tLTVIV0U2VkNNOVZnQkJJcVRrTTVZN0E9PQ%3D%3D--22b4739c0c0cd29ad8454705bf8ed74ef7b490b9; _ga_4X9PJ2ZDMR=GS2.2.s1774185008$o8$g1$t1774185018$j50$l0$h0",
                "Referer": "https://hmdb.ca/spectra/ms/search"
            },
            body
        });

        const html = await response.text();
        const parser = new DOMParser();
        const doc = parser.parseFromString(html, "text/html");

        const sections = doc.querySelectorAll(".panel-heading, h3");
        sections.forEach(section => {
            const text = section.innerText;
            const match = text.match(/MS search for ([\d.]+) m\/z/);
            if (!match) return;

            const mz = match[1];
            const table = section.parentElement.querySelector("table tbody");
            if (!table) return;

            const rows = table.querySelectorAll("tr");
            resultObj[mz] = Array.from(rows).map(row => {
                const cells = row.querySelectorAll("td");
                return {
                    "Query m/z": mz,
                    Compound: cells[0]?.innerText.trim() || "",
                    Name: cells[1]?.innerText.trim() || "",
                    Formula: cells[2]?.innerText.trim() || "",
                    "Monoisotopic Mass": cells[3]?.innerText.trim() || "",
                    Adduct: cells[4]?.innerText.trim() || "",
                    "Adduct M/Z": cells[5]?.innerText.trim() || "",
                    "Delta (ppm)": cells[6]?.innerText.trim() || "",
                    CCS: cells[7]?.innerText.trim() || ""
                };
            });
        });

        const allRows = [];
        for (const mz in resultObj) {
            allRows.push(...resultObj[mz]);
        }

        if (!allRows.length) {
            console.warn(`[${filename}] 没有数据可导出`);
            return;
        }

        const headers = Object.keys(allRows[0]);
        const csvContent = [
            headers.join(","),
            ...allRows.map(row => headers.map(h => `"${row[h].replace(/"/g, '""')}"`).join(","))
        ].join("\n");

        const blob = new Blob([csvContent], { type: "text/csv;charset=utf-8;" });
        const link = document.createElement("a");
        link.href = URL.createObjectURL(blob);
        link.setAttribute("download", filename);
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);

        console.log(`✅ CSV 文件已生成: ${filename}`);
        return resultObj;

    } catch (err) {
        console.error(`❌ [${filename}] 请求失败:`, err);
        return {};
    }
}

