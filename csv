// ==================== 每次请求两个 mass ====================
/**
 * 单次 fetch，遇到 503 自动重试（最多 MAX_RETRY 次，指数退避）
 */
async function fetchWithRetry(body, MAX_RETRY = 5) {
    let delay = 3000; // 初始等待 3 秒
    for (let attempt = 1; attempt <= MAX_RETRY; attempt++) {
        const response = await fetch('https://hmdb.ca/spectra/ms/search', {
            method: 'POST',
            headers: HMDB_HEADERS,
            body,
            referrer: 'https://hmdb.ca/spectra/ms/search',
            referrerPolicy: 'strict-origin-when-cross-origin',
            mode: 'cors',
            credentials: 'include',
        });

        if (response.status === 503) {
            console.warn(`⚠️ 503 限流，第 ${attempt} 次重试，等待 ${delay / 1000}s...`);
            await new Promise((r) => setTimeout(r, delay));
            delay *= 2; // 指数退避
            continue;
        }
        return response; // 正常返回
    }
    throw new Error('请求多次 503，已放弃');
}

/**
 * 请求一批 mass 值（最多 100 个），返回 { [mz]: true/false }
 */
async function fetchBatch(masses) {
    // 用 %0D%0A 分隔（即 \r\n URL 编码），与浏览器原始请求一致
    const massPart = masses.map(encodeURIComponent).join('%0D%0A');
    const body = `utf8=%E2%9C%93&authenticity_token=FS1hIJVdGqAKv4LlA0BSeyX3EggX6IcE7Hi8ZO2IagrXLQsctU3YoKulzxOHiOVrAa0i7mNpQv%2B5uS9SJimT7A%3D%3D&query_masses=${massPart}&ms_search_ion_mode=negative&adduct_type%5B%5D=M-H&adduct_type%5B%5D=M-H20-H&adduct_type%5B%5D=M%2BCl&adduct_type%5B%5D=M%2BFA-H&tolerance=10&tolerance_units=ppm&ccs_predictors=&ccs_tolerance=&commit=Search`;

    const result = {};
    masses.forEach((mz) => (result[mz] = false));

    try {
        const response = await fetchWithRetry(body);
        const html = await response.text();
        const parser = new DOMParser();
        const doc = parser.parseFromString(html, 'text/html');

        const msTables = doc.querySelectorAll('.ms-search-table[data-query-mass]');
        msTables.forEach((tableDiv) => {
            const mz = tableDiv.getAttribute('data-query-mass');
            if (!mz) return;
            const tbody = tableDiv.querySelector('table tbody');
            if (tbody && tbody.querySelectorAll('tr').length > 0) {
                result[mz] = true;
            }
        });
    } catch (err) {
        console.error(`❌ 请求失败 [${masses[0]} ... ${masses[masses.length - 1]}]:`, err);
    }

    return result;
}

// ==================== 并行处理 + 导出 CSV ====================
async function runHMDBYesNo() {
    const allItems = [
        ...queryMasses1,
        ...queryMasses2,
        ...queryMasses3,
        ...queryMasses4,
        ...queryMasses5,
        ...queryMasses6,
        ...queryMasses7,
        ...queryMasses8,
        ...queryMasses9,
        ...queryMasses10,
        ...queryMasses11,
        ...queryMasses12,
        ...queryMasses13,
        ...queryMasses14,
        ...queryMasses15,
        ...queryMasses16,
        ...queryMasses17,
        ...queryMasses18,
        ...queryMasses19,
        ...queryMasses20,
        ...queryMasses21,
        ...queryMasses22,
        ...queryMasses23,
        ...queryMasses24,
    ];

    const total = allItems.length;
    console.log(`📊 总数据: ${total} 条`);

    // 每次请求 100 个，切分成若干块
    const CHUNK_SIZE = 100;       // 每个请求携带的 mass 数量
    const PARALLEL = 3;           // 同时并发的请求数
    const INTER_BATCH_DELAY = 2000; // 每轮完成后等待 2 秒

    const chunks = [];
    for (let i = 0; i < allItems.length; i += CHUNK_SIZE) {
        chunks.push(allItems.slice(i, i + CHUNK_SIZE));
    }
    console.log(`📦 共 ${chunks.length} 个请求块，每块最多 ${CHUNK_SIZE} 条，每轮并行 ${PARALLEL} 个`);

    const valueResults = {}; // { value字符串: boolean }

    for (let i = 0; i < chunks.length; i += PARALLEL) {
        const round = chunks.slice(i, i + PARALLEL); // 本轮最多 3 个块

        // 每个 chunk 是 {name,value}[] → 提取 value 数组传给 fetchBatch
        const roundResults = await Promise.all(round.map(batch => fetchBatch(batch.map(item => item.value))));
        roundResults.forEach(r => Object.assign(valueResults, r));

        const done = Math.min((i + PARALLEL) * CHUNK_SIZE, total);
        console.log(`⏳ 进度: ${done} / ${total}`);

        if (i + PARALLEL < chunks.length) {
            await new Promise((resolve) => setTimeout(resolve, INTER_BATCH_DELAY));
        }
    }

    // 导出 CSV：name, m/z, 是/否
    const csvLines = ['name,m/z,是否有数据'];
    allItems.forEach(item => {
        csvLines.push(`${item.name},${item.value},${valueResults[item.value] ? '是' : '否'}`);
    });

    const csvContent = '\uFEFF' + csvLines.join('\n');
    const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
    const link = document.createElement('a');
    link.href = URL.createObjectURL(blob);
    link.setAttribute('download', 'hmdb_results_yesno.csv');
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);

    console.log(`✅ CSV 已导出: hmdb_results_yesno.csv（共 ${total} 条）`);
}

// ==================== 启动 ====================
runHMDBYesNo().then(() => console.log('🎉 全部完成！')).catch((e) => console.error('❌ 运行出错:', e));
